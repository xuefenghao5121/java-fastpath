+    /**
+     * Fast check if char array matches financial format.
+     * Financial pattern: optional sign, 1-12 digits, optional decimal point,
+     * exactly 2 (currency) or 4 (percentage) fraction digits.
+     * @return scale if matches financial pattern, -1 otherwise
+     */
+    private static int checkFinancialFastPath(char[] in, int offset, int len) {
+        if (len < 1 || len > 18) return -1;
+        int pos = offset;
+        int end = offset + len;
+        // Check optional sign
+        if (in[pos] == '+' || in[pos] == '-') {
+            pos++;
+            if (pos >= end) return -1;
+        }
+        int digitCount = 0;
+        int decimalPos = -1;
+        // Scan digits and decimal point
+        for (; pos < end; pos++) {
+            char c = in[pos];
+            if (c >= '0' && c <= '9') {
+                digitCount++;
+                if (digitCount > 12) return -1;
+            } else if (c == '.') {
+                if (decimalPos != -1) return -1;
+                decimalPos = digitCount;
+            } else {
+                return -1;
+            }
+        }
+        if (digitCount == 0) return -1;
+        // Determine scale
+        if (decimalPos == -1) return 0;
+        int fractionDigits = digitCount - decimalPos;
+        if (fractionDigits == 2) return 2;
+        if (fractionDigits == 4) return 4;
+        return -1;
+    }
