+            isneg = (in[pos] == '-');
+            pos++;
+        }
+        // Parse digits (ignore decimal point)
+        long value = 0;
+        for (; pos < end; pos++) {
+            char c = in[pos];
+            if (c >= '0' && c <= '9') {
+                value = value * 10 + (c - '0');
+            }
+        }
+        if (isneg) value = -value;
+        BigDecimal result = valueOf(value, scale);
+        return mc.precision == 0 ? result : result.round(mc);
+    }
